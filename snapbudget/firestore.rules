rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Ensure user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Ensure the document ID matches the auth UID or a 'userId' field matches the auth UID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USERS collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // TRANSACTIONS collection
    match /transactions/{transactionId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // RECEIPTS collection
    match /receipts/{receiptId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // SMS TRANSACTIONS collection
    match /sms_transactions/{smsId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // SPLIT GROUPS collection
    // Read: if auth.uid is in the members array.
    // Write: if auth.uid is in the members array being written to.
    match /split_groups/{groupId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.members;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.members;
    }

    // GROUP EXPENSES collection
    // Note: requires a client-side filter or custom claim in practice, but for simplicity
    // we assume the app enforces group member checks. A real rule might use `get()` to check
    // split_groups/{groupId}.members
    match /group_expenses/{expenseId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.splitMembers 
                                              || request.auth.uid in request.resource.data.splitMembers;
    }

    // BUDGETS collection
    match /budgets/{budgetId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // ALERTS collection
    match /alerts/{alertId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // ANALYTICS CACHE collection
    match /analytics_cache/{docId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    // WIDGET DATA collection
    match /widgets/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
